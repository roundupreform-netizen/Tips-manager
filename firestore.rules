rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // Default Deny
    match /{document=**} {
      allow read, write: if false;
    }

    // --- GLOBAL HELPERS ---
    function isSignedIn() { return request.auth != null; }
    function isValidId(id) { return id is string && id.size() <= 128 && id.matches('^[a-zA-Z0-9_\\-]+$'); }
    function incoming() { return request.resource.data; }
    function existing() { return resource.data; }
    
    // Role Checks (using user profile in Firestore)
    function getProfile() {
      return get(/databases/$(database)/documents/users/$(request.auth.uid)).data;
    }
    function hasProfile() {
      return isSignedIn() && exists(/databases/$(database)/documents/users/$(request.auth.uid));
    }
    function isAdmin() {
      return hasProfile() && getProfile().role == 'admin' && getProfile().active == true;
    }
    function isManager() {
      return hasProfile() && (getProfile().role == 'manager' || getProfile().role == 'admin') && getProfile().active == true;
    }
    function isStaff() {
      return hasProfile() && getProfile().active == true;
    }
    function isOwner(userId) {
      return isSignedIn() && request.auth.uid == userId;
    }

    // --- COLLECTIONS ---

    // Collection: Users
    match /users/{userId} {
      allow get: if isStaff() || isOwner(userId);
      allow list: if isSignedIn();
      allow create: if isSignedIn() && isOwner(userId);
      allow update: if isAdmin() || (isOwner(userId) && incoming().role == existing().role);
      allow delete: if isAdmin();
    }

    // Collection: Staff (Roster)
    match /staff/{staffId} {
      allow read: if isSignedIn();
      allow write: if isManager();
    }

    // Collection: Deleted Staff (Archives)
    match /deleted_staff/{staffId} {
      allow read: if isManager();
      allow write: if isManager();
    }

    // Collection: Advances
    match /advances/{advanceId} {
      allow read: if isStaff();
      allow write: if isManager();
    }

    // Collection: Penalties
    match /penalties/{penaltyId} {
      allow read: if isStaff();
      allow create: if isManager();
      allow delete: if isManager();
    }

    // Collection: Inventory
    match /inventory/{docId} {
      allow read: if isSignedIn();
      allow write: if isManager();
    }

    // Collection: Settings
    match /settings/{docId} {
      allow read: if isSignedIn();
      allow write: if isAdmin();
    }

    // Collection: Roles
    match /roles/{roleId} {
      allow read: if isSignedIn();
      allow write: if isAdmin();
    }

    // Collection: Staff Logs
    match /staff_logs/{logId} {
      allow read: if isManager();
      allow create: if isStaff();
    }
  }
}
