rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {
    // Default Deny
    match /{document=**} {
      allow read, write: if false;
    }

    // Global Helpers
    function isSignedIn() { return request.auth != null; }

    // This application uses a local-to-cloud migration strategy on first run.
    // To support initial setup, the following rules allow unauthenticated writes.
    // It is RECOMMENDED to enable Firebase Auth and restrict these rules later.

    match /staff/{docId} { allow read, write: if true; }
    match /deleted_staff/{docId} { allow read, write: if true; }
    match /staff_logs/{docId} { allow read, write: if true; }
    match /advances/{docId} { allow read, write: if true; }
    match /penalties/{docId} { allow read, write: if true; }
    match /inventory/{docId} { allow read, write: if true; }
    match /settings/{docId} { allow read, write: if true; }
    match /users/{docId} { allow read, write: if true; }
    match /roles/{docId} { allow read, write: if true; }
  }
}
